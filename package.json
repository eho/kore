{
  "name": "@kore/root",
  "private": true,
  "scripts": {
    "start": "bun run apps/core-api/src/index.ts",
    "dev": "bun --hot run apps/core-api/src/index.ts",
    "test": "bun test apps packages",
    "test:e2e": "bun test ./e2e/run.e2e.ts",
    "typecheck": "bunx tsc --noEmit --project tsconfig.json",
    "build:bin": "bun run --cwd apps/core-api build:bin && bun run --cwd apps/cli build:bin"
  },
  "workspaces": [
    "./packages/*",
    "./apps/*"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@tobilu/qmd": "^2.0.1",
    "ai": "^6.0.116",
    "protobufjs": "^8.0.0"
  }
}