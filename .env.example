# Base directory for all Kore data (db files, notes storage).
# Defaults to ~/.kore if not set.
KORE_HOME=~/.kore

KORE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# QMD model cache: GGUF models (~2GB+) are stored in ~/.cache/qmd (via XDG_CACHE_HOME).
# Override with: XDG_CACHE_HOME=/your/path (models will go to /your/path/qmd)

# Interval (ms) between periodic embed() calls for vector embeddings (default: 5 min)
KORE_EMBED_INTERVAL_MS=300000

# ─── Consolidation ─────────────────────────────────────────────────
# How often the consolidation loop runs (default: 1800000 = 30 minutes)
CONSOLIDATION_INTERVAL_MS=1800000

# Minimum days before a memory can be re-consolidated (default: 7)
CONSOLIDATION_COOLDOWN_DAYS=7

# Max synthesis attempts before marking a seed as failed (default: 3)
CONSOLIDATION_MAX_ATTEMPTS=3

# Optional: override the LLM model used for insight synthesis
# Falls back to OLLAMA_MODEL / LLM_MODEL if not set
# KORE_SYNTHESIS_MODEL=

# ─── MCP Server ────────────────────────────────────────────────────
# Enable the embedded MCP server on core-api (default: true)
KORE_MCP_ENABLED=true

# HTTP route path for the MCP server (default: /mcp)
KORE_MCP_PATH=/mcp

# Default limit for recall results when called via MCP (default: 10)
KORE_MCP_DEFAULT_RECALL_LIMIT=10

# Minimum QMD relevance score for recall results (default: 0.0)
KORE_MCP_MIN_SCORE=0.0

# ─── Apple Notes Plugin ─────────────────────────────────────────────
# Enable the Apple Notes sync plugin (requires Full Disk Access on macOS)
KORE_APPLE_NOTES_ENABLED=false

# Sync interval in milliseconds (default: 900000 = 15 minutes)
KORE_AN_SYNC_INTERVAL_MS=900000

# Include handwriting OCR text from drawings (default: false)
KORE_AN_INCLUDE_HANDWRITING=false

# Comma-separated folder allowlist — only sync notes in these top-level folders
# Leave empty to sync all folders (subject to blocklist)
KORE_AN_FOLDER_ALLOWLIST=

# Comma-separated folder blocklist — exclude notes in these top-level folders
KORE_AN_FOLDER_BLOCKLIST=

# Override Apple Notes database directory (default: ~/Library/Group Containers/group.com.apple.notes)
# Useful for local testing with a copied database — no Full Disk Access required
# KORE_AN_DB_DIR=~/dev/kore/e2e/notes-testdata/group.com.apple.notes
